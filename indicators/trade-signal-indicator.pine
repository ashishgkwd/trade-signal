// This Pine Script indicator combines multiple indicators to generate trading signals
// © Custom Trading Signal Indicator
// @version=6

//@version=6
indicator("Trade Signal Indicator", shorttitle="TSI", overlay=true, max_bars_back=1200, max_lines_count=500, max_labels_count=500)

// ============================================================================
// INPUT SETTINGS
// ============================================================================

// === Enable/Disable Indicators ===
string groupEnable = "Enable/Disable Indicators"
bool enableEMA = input.bool(true, "Enable EMA Cross Strategy", group=groupEnable)
bool enableATF = input.bool(true, "Enable Adaptive Trend Finder", group=groupEnable)
bool enableNWE = input.bool(true, "Enable Nadaraya-Watson Envelope", group=groupEnable)

// === EMA Cross Strategy Settings ===
string groupEMA = "EMA Cross Strategy"
int emaFast = input.int(13, "Fast EMA", minval=1, maxval=9999, group=groupEMA)
int emaSlow = input.int(48, "Slow EMA", minval=1, maxval=9999, group=groupEMA)
color emaFastColor = input.color(color.orange, "Fast EMA Color", group=groupEMA, inline="ema1")
color emaSlowColor = input.color(color.blue, "Slow EMA Color", group=groupEMA, inline="ema1")

// === Adaptive Trend Finder Settings ===
string groupATF = "Adaptive Trend Finder"
float atfSourceInput = input.source(close, title = 'Source', group=groupATF)
bool atfPeriodMode = input.bool(false, "Use Long-Term Channel", group=groupATF)
float atfDevMultiplier = input.float(2.0, "Deviation Multiplier", group=groupATF, step=0.1)
color atfColor = input.color(color.gray, "Channel Color", group=groupATF, inline="atf1")
int atfFillTransp = input.int(93, "Fill Transp", group=groupATF, inline="atf2", minval=0, maxval=100)
int atfLineTransp = input.int(40, "Line Transp", group=groupATF, inline="atf2", minval=0, maxval=100)

// === Nadaraya-Watson Envelope Settings ===
string groupNWE = "Nadaraya-Watson Envelope"
float nweBandwidth = input.float(8.0, "Bandwidth", minval=0, group=groupNWE)
float nweMultiplier = input.float(3.0, "Multiplier", minval=0, group=groupNWE)
float nweSource = input.source(close, "Source", group=groupNWE)
bool nweRepaint = input.bool(true, "Repainting Smoothing", group=groupNWE, tooltip="Repainting is an effect where the indicators historical output is subject to change over time. Disabling repainting will cause the indicator to output the endpoints of the calculations")
color nweUpColor = input.color(color.teal, "Up Color", group=groupNWE, inline="nwe1")
color nweDnColor = input.color(color.red, "Down Color", group=groupNWE, inline="nwe1")

// === Signal Display Settings ===
string groupSignal = "Signal Display"
bool showBuySignals = input.bool(true, "Show Buy Signals", group=groupSignal)
bool showSellSignals = input.bool(true, "Show Sell Signals", group=groupSignal)
bool showLabels = input.bool(true, "Show Signal Labels", group=groupSignal)

// ============================================================================
// INDICATOR 1: EMA CROSS STRATEGY
// ============================================================================

// Calculate EMAs
float fastEMA = ta.ema(close, emaFast)
float slowEMA = ta.ema(close, emaSlow)

// EMA signals
bool emaLongSignal = ta.crossover(fastEMA, slowEMA)
bool emaShortSignal = ta.crossunder(fastEMA, slowEMA)

// Determine current EMA trend
bool emaBullish = fastEMA > slowEMA
bool emaBearish = fastEMA < slowEMA

// Plot EMAs (only if enabled)
plot(enableEMA ? fastEMA : na, "Fast EMA", color=emaFastColor, linewidth=2)
plot(enableEMA ? slowEMA : na, "Slow EMA", color=emaSlowColor, linewidth=2)

// ============================================================================
// INDICATOR 2: ADAPTIVE TREND FINDER
// ============================================================================

// Calculate deviations for given length
calcDev(float source, int length) =>
    float logSource = math.log(source)
    var int period_1 = length - 1
    if barstate.islast
        float sumX = 0.0
        float sumXX = 0.0
        float sumYX = 0.0
        float sumY = 0.0
        for int i = 1 to length by 1
            float lSrc = logSource[i - 1]
            sumX := sumX + i
            sumXX := sumXX + i * i
            sumYX := sumYX + i * lSrc
            sumY := sumY + lSrc
            sumY
        float slope = nz((length * sumYX - sumX * sumY) / (length * sumXX - sumX * sumX))
        float average = sumY / length
        float intercept = average - slope * sumX / length + slope
        float sumDev = 0.0
        float sumDxx = 0.0
        float sumDyy = 0.0
        float sumDyx = 0.0
        float regres = intercept + slope * period_1 * 0.5
        float sumSlp = intercept
        for int i = 0 to period_1 by 1
            float lSrc = logSource[i]
            float dxt = lSrc - average
            float dyt = sumSlp - regres
            lSrc := lSrc - sumSlp
            sumSlp := sumSlp + slope
            sumDxx := sumDxx + dxt * dxt
            sumDyy := sumDyy + dyt * dyt
            sumDyx := sumDyx + dxt * dyt
            sumDev := sumDev + lSrc * lSrc
            sumDev
        float unStdDev = math.sqrt(sumDev / period_1)
        float divisor = sumDxx * sumDyy
        float pearsonR = nz(sumDyx / math.sqrt(divisor))
        [unStdDev, pearsonR, slope, intercept]
    else
        [na, na, na, na]

// ATF Period arrays
var array<int> atfPeriods = atfPeriodMode ? array.from(na, 300, 350, 400, 450, 500, 550, 600, 650, 700, 750, 800, 850, 900, 950, 1000, 1050, 1100, 1150, 1200) : array.from(na, 20, 30, 40, 50, 60, 70, 80, 90, 100, 110, 120, 130, 140, 150, 160, 170, 180, 190, 200)

// Calculate deviations for all periods
[stdDev01, pearsonR01, slope01, intercept01] = calcDev(atfSourceInput, atfPeriods.get(1))
[stdDev02, pearsonR02, slope02, intercept02] = calcDev(atfSourceInput, atfPeriods.get(2))
[stdDev03, pearsonR03, slope03, intercept03] = calcDev(atfSourceInput, atfPeriods.get(3))
[stdDev04, pearsonR04, slope04, intercept04] = calcDev(atfSourceInput, atfPeriods.get(4))
[stdDev05, pearsonR05, slope05, intercept05] = calcDev(atfSourceInput, atfPeriods.get(5))
[stdDev06, pearsonR06, slope06, intercept06] = calcDev(atfSourceInput, atfPeriods.get(6))
[stdDev07, pearsonR07, slope07, intercept07] = calcDev(atfSourceInput, atfPeriods.get(7))
[stdDev08, pearsonR08, slope08, intercept08] = calcDev(atfSourceInput, atfPeriods.get(8))
[stdDev09, pearsonR09, slope09, intercept09] = calcDev(atfSourceInput, atfPeriods.get(9))
[stdDev10, pearsonR10, slope10, intercept10] = calcDev(atfSourceInput, atfPeriods.get(10))
[stdDev11, pearsonR11, slope11, intercept11] = calcDev(atfSourceInput, atfPeriods.get(11))
[stdDev12, pearsonR12, slope12, intercept12] = calcDev(atfSourceInput, atfPeriods.get(12))
[stdDev13, pearsonR13, slope13, intercept13] = calcDev(atfSourceInput, atfPeriods.get(13))
[stdDev14, pearsonR14, slope14, intercept14] = calcDev(atfSourceInput, atfPeriods.get(14))
[stdDev15, pearsonR15, slope15, intercept15] = calcDev(atfSourceInput, atfPeriods.get(15))
[stdDev16, pearsonR16, slope16, intercept16] = calcDev(atfSourceInput, atfPeriods.get(16))
[stdDev17, pearsonR17, slope17, intercept17] = calcDev(atfSourceInput, atfPeriods.get(17))
[stdDev18, pearsonR18, slope18, intercept18] = calcDev(atfSourceInput, atfPeriods.get(18))
[stdDev19, pearsonR19, slope19, intercept19] = calcDev(atfSourceInput, atfPeriods.get(19))

// Variables to store ATF trend
var float atfSlope = na
var bool atfBullish = false
var bool atfBearish = false

if barstate.islast and enableATF
    // Find the highest Pearson's R
    float highestPearsonR = math.max(pearsonR01, pearsonR02, pearsonR03, pearsonR04, pearsonR05, pearsonR06, pearsonR07, pearsonR08, pearsonR09, pearsonR10, pearsonR11, pearsonR12, pearsonR13, pearsonR14, pearsonR15, pearsonR16, pearsonR17, pearsonR18, pearsonR19)
    
    // Determine selected parameters
    int detectedPeriod = na
    float detectedSlope = na
    float detectedIntrcpt = na
    float detectedStdDev = na
    
    switch highestPearsonR
        pearsonR01 =>
            detectedPeriod := atfPeriods.get(1)
            detectedSlope := slope01
            detectedIntrcpt := intercept01
            detectedStdDev := stdDev01
        pearsonR02 =>
            detectedPeriod := atfPeriods.get(2)
            detectedSlope := slope02
            detectedIntrcpt := intercept02
            detectedStdDev := stdDev02
        pearsonR03 =>
            detectedPeriod := atfPeriods.get(3)
            detectedSlope := slope03
            detectedIntrcpt := intercept03
            detectedStdDev := stdDev03
        pearsonR04 =>
            detectedPeriod := atfPeriods.get(4)
            detectedSlope := slope04
            detectedIntrcpt := intercept04
            detectedStdDev := stdDev04
        pearsonR05 =>
            detectedPeriod := atfPeriods.get(5)
            detectedSlope := slope05
            detectedIntrcpt := intercept05
            detectedStdDev := stdDev05
        pearsonR06 =>
            detectedPeriod := atfPeriods.get(6)
            detectedSlope := slope06
            detectedIntrcpt := intercept06
            detectedStdDev := stdDev06
        pearsonR07 =>
            detectedPeriod := atfPeriods.get(7)
            detectedSlope := slope07
            detectedIntrcpt := intercept07
            detectedStdDev := stdDev07
        pearsonR08 =>
            detectedPeriod := atfPeriods.get(8)
            detectedSlope := slope08
            detectedIntrcpt := intercept08
            detectedStdDev := stdDev08
        pearsonR09 =>
            detectedPeriod := atfPeriods.get(9)
            detectedSlope := slope09
            detectedIntrcpt := intercept09
            detectedStdDev := stdDev09
        pearsonR10 =>
            detectedPeriod := atfPeriods.get(10)
            detectedSlope := slope10
            detectedIntrcpt := intercept10
            detectedStdDev := stdDev10
        pearsonR11 =>
            detectedPeriod := atfPeriods.get(11)
            detectedSlope := slope11
            detectedIntrcpt := intercept11
            detectedStdDev := stdDev11
        pearsonR12 =>
            detectedPeriod := atfPeriods.get(12)
            detectedSlope := slope12
            detectedIntrcpt := intercept12
            detectedStdDev := stdDev12
        pearsonR13 =>
            detectedPeriod := atfPeriods.get(13)
            detectedSlope := slope13
            detectedIntrcpt := intercept13
            detectedStdDev := stdDev13
        pearsonR14 =>
            detectedPeriod := atfPeriods.get(14)
            detectedSlope := slope14
            detectedIntrcpt := intercept14
            detectedStdDev := stdDev14
        pearsonR15 =>
            detectedPeriod := atfPeriods.get(15)
            detectedSlope := slope15
            detectedIntrcpt := intercept15
            detectedStdDev := stdDev15
        pearsonR16 =>
            detectedPeriod := atfPeriods.get(16)
            detectedSlope := slope16
            detectedIntrcpt := intercept16
            detectedStdDev := stdDev16
        pearsonR17 =>
            detectedPeriod := atfPeriods.get(17)
            detectedSlope := slope17
            detectedIntrcpt := intercept17
            detectedStdDev := stdDev17
        pearsonR18 =>
            detectedPeriod := atfPeriods.get(18)
            detectedSlope := slope18
            detectedIntrcpt := intercept18
            detectedStdDev := stdDev18
        =>  // pearsonR19
            detectedPeriod := atfPeriods.get(19)
            detectedSlope := slope19
            detectedIntrcpt := intercept19
            detectedStdDev := stdDev19
    
    atfSlope := detectedSlope
    atfBullish := detectedSlope > 0
    atfBearish := detectedSlope < 0
    
    // Draw ATF channel
    var line upperLine = na
    var line baseLine = na
    var line lowerLine = na
    var linefill upperFill = na
    var linefill lowerFill = na
    
    float startPrice = math.exp(detectedIntrcpt + detectedSlope * (detectedPeriod - 1))
    float endPrice = math.exp(detectedIntrcpt)
    int startAtBar = bar_index - detectedPeriod + 1
    
    var color channelColor = color.new(atfColor, atfLineTransp)
    
    if na(baseLine)
        baseLine := line.new(startAtBar, startPrice, bar_index, endPrice, width=1, extend=extend.right, color=color.new(atfColor, 50), style=line.style_dashed)
    else
        line.set_xy1(baseLine, startAtBar, startPrice)
        line.set_xy2(baseLine, bar_index, endPrice)
    
    float upperStartPrice = startPrice * math.exp(atfDevMultiplier * detectedStdDev)
    float upperEndPrice = endPrice * math.exp(atfDevMultiplier * detectedStdDev)
    if na(upperLine)
        upperLine := line.new(startAtBar, upperStartPrice, bar_index, upperEndPrice, width=1, extend=extend.right, color=channelColor, style=line.style_solid)
    else
        line.set_xy1(upperLine, startAtBar, upperStartPrice)
        line.set_xy2(upperLine, bar_index, upperEndPrice)
    
    float lowerStartPrice = startPrice / math.exp(atfDevMultiplier * detectedStdDev)
    float lowerEndPrice = endPrice / math.exp(atfDevMultiplier * detectedStdDev)
    if na(lowerLine)
        lowerLine := line.new(startAtBar, lowerStartPrice, bar_index, lowerEndPrice, width=1, extend=extend.right, color=channelColor, style=line.style_solid)
    else
        line.set_xy1(lowerLine, startAtBar, lowerStartPrice)
        line.set_xy2(lowerLine, bar_index, lowerEndPrice)
    
    if na(upperFill)
        upperFill := linefill.new(upperLine, baseLine, color=color.new(atfColor, atfFillTransp))
    if na(lowerFill)
        lowerFill := linefill.new(baseLine, lowerLine, color=color.new(atfColor, atfFillTransp))

// ============================================================================
// INDICATOR 3: NADARAYA-WATSON ENVELOPE
// ============================================================================

// Gaussian window function
gauss(x, h) => math.exp(-(math.pow(x, 2) / (h * h * 2)))

// Variables for both modes
var coefs = array.new_float(0)
var den = 0.

n = bar_index

// End point method (non-repainting) - initialize coefficients
if barstate.isfirst and not nweRepaint
    for i = 0 to 499
        w = gauss(i, nweBandwidth)
        coefs.push(w)
    den := coefs.sum()

// Non-repainting mode calculation
out = 0.
if not nweRepaint
    for i = 0 to 499
        out += nweSource[i] * coefs.get(i)
out /= den
mae = ta.sma(math.abs(nweSource - out), 499) * nweMultiplier

nweUpper = out + mae
nweLower = out - mae

// Repainting mode - draw lines (similar to original implementation)
float y2 = na
float y1 = na
var nweArray = array.new<float>(0)

if barstate.islast and nweRepaint and enableNWE
    nweArray.clear()
    sae = 0.
    
    // Compute Nadaraya-Watson values for each bar
    for i = 0 to math.min(499, n - 1)
        sum = 0.
        sumw = 0.
        
        // Compute weighted mean for bar i
        for j = 0 to math.min(499, n - 1)
            w = gauss(i - j, nweBandwidth)
            sum += nweSource[j] * w
            sumw += w
        
        y2 := sum / sumw
        sae += math.abs(nweSource[i] - y2)
        nweArray.push(y2)
    
    // Calculate mean absolute error
    sae := sae / math.min(499, n - 1) * nweMultiplier
    
    // Draw lines for the envelope and generate signals
    for i = 0 to math.min(499, n - 1)
        if i % 2 > 0  // Draw every other line for performance
            line.new(n - i + 1, y1 + sae, n - i, nweArray.get(i) + sae, color=nweUpColor, width=1)
            line.new(n - i + 1, y1 - sae, n - i, nweArray.get(i) - sae, color=nweDnColor, width=1)
        
        // --- Signal Detection in Repainting Mode ---
        // Crossunder Lower Band (Potential Buy)
        if nweSource[i] < nweArray.get(i) - sae and nweSource[i + 1] > nweArray.get(i) - sae
            // Apply Filters: EMA and ATF
            bool emaCond = enableEMA ? (fastEMA[i] > slowEMA[i]) : true
            bool atfCond = enableATF ? atfBullish : true // Uses current ATF trend
            
            if showBuySignals and emaCond and atfCond
                label.new(n - i, nweSource[i], showLabels ? "BUY" : "▲", color=color.new(color.green, 0), style=label.style_label_up, textcolor=color.white, textalign=text.align_center, size=size.small)

        // Crossover Upper Band (Potential Sell)
        if nweSource[i] > nweArray.get(i) + sae and nweSource[i + 1] < nweArray.get(i) + sae
            // Apply Filters: EMA and ATF
            bool emaCond = enableEMA ? (fastEMA[i] < slowEMA[i]) : true
            bool atfCond = enableATF ? atfBearish : true // Uses current ATF trend
            
            if showSellSignals and emaCond and atfCond
                label.new(n - i, nweSource[i], showLabels ? "SELL" : "▼", color=color.new(color.red, 0), style=label.style_label_down, textcolor=color.white, textalign=text.align_center, size=size.small)
        
        y1 := nweArray.get(i)
    
    // Update values for signal detection (use most recent bar)
    if nweArray.size() > 0
        nweUpper := nweArray.get(0) + sae
        nweLower := nweArray.get(0) - sae

// NWE signals - using the same logic as the original
bool nweBuySignal = ta.crossunder(close, nweLower)
bool nweSellSignal = ta.crossover(close, nweUpper)

// Determine current NWE position
bool nweAboveUpper = close > nweUpper
bool nweBelowLower = close < nweLower
bool nweInChannel = not nweAboveUpper and not nweBelowLower

// Plot NWE (only if enabled and NOT in repainting mode)
// In repainting mode, lines are drawn above instead of using plot
plot(enableNWE and not nweRepaint ? nweUpper : na, "NWE Upper", color=nweUpColor, linewidth=2)
plot(enableNWE and not nweRepaint ? nweLower : na, "NWE Lower", color=nweDnColor, linewidth=2)

// ============================================================================
// COMBINED SIGNAL LOGIC
// ============================================================================

// print atfBearish and atfBullish
print("atfBearish: " + str.tostring(atfBearish))
print("atfBullish: " + str.tostring(atfBullish))

// Buy Signal Logic:
// - NWE: Price crosses under lower band (buy signal)
// - ATF: Trend is bullish (slope > 0) OR disabled
// - EMA: Fast EMA above Slow EMA (bullish) OR disabled
bool buyCondition = (enableNWE ? nweBuySignal : false) and
                    (enableATF ? atfBullish : true) and
                    (enableEMA ? emaBullish : true)

// Sell Signal Logic:
// - NWE: Price crosses over upper band (sell signal)
// - ATF: Trend is bearish (slope < 0) OR disabled
// - EMA: Fast EMA below Slow EMA (bearish) OR disabled
bool sellCondition = (enableNWE ? nweSellSignal : false) and
                     (enableATF ? atfBearish : true) and
                     (enableEMA ? emaBearish : true)

// Alternative: If NWE is disabled, use EMA crossover/crossunder as primary signal
if not enableNWE and enableEMA
    buyCondition := emaLongSignal and (enableATF ? atfBullish : true)
    sellCondition := emaShortSignal and (enableATF ? atfBearish : true)

// ============================================================================
// PLOT SIGNALS
// ============================================================================

// Plot buy signals with labels
plotshape(
    showBuySignals and buyCondition and showLabels ? low : na,
    "Buy Signal Label",
    shape.labelup,
    location.belowbar,
    color.new(color.green, 0),
    text="BUY",
    textcolor=color.white,
    size=size.small
)

// Plot buy signals with arrows (when labels are disabled)
plotshape(
    showBuySignals and buyCondition and not showLabels ? low : na,
    "Buy Signal Arrow",
    shape.triangleup,
    location.belowbar,
    color.new(color.green, 0),
    size=size.small
)

// Plot sell signals with labels
plotshape(
    showSellSignals and sellCondition and showLabels ? high : na,
    "Sell Signal Label",
    shape.labeldown,
    location.abovebar,
    color.new(color.red, 0),
    text="SELL",
    textcolor=color.white,
    size=size.small
)

// Plot sell signals with arrows (when labels are disabled)
plotshape(
    showSellSignals and sellCondition and not showLabels ? high : na,
    "Sell Signal Arrow",
    shape.triangledown,
    location.abovebar,
    color.new(color.red, 0),
    size=size.small
)

// ============================================================================
// ALERTS
// ============================================================================

// Alert conditions
alertcondition(buyCondition, title="Buy Signal", message="Trade Signal Indicator: BUY signal generated")
alertcondition(sellCondition, title="Sell Signal", message="Trade Signal Indicator: SELL signal generated")

// ============================================================================
// BACKGROUND COLORING (Optional visual aid)
// ============================================================================

// Color background based on overall trend
bgcolor(
    buyCondition ? color.new(color.green, 95) :
    sellCondition ? color.new(color.red, 95) :
    na,
    title="Signal Background"
)
